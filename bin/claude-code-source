#!/usr/bin/env node

import { spawnSync } from 'node:child_process';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import bunGuard from '../scripts/require-bun.cjs';

const { ensureBunVersion } = bunGuard;

ensureBunVersion('1.2.0');

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const cliPath = path.resolve(__dirname, '..', 'dist', 'cli.js');
const args = process.argv.slice(2);
const result = spawnSync('bun', [cliPath, ...args], { stdio: 'inherit' });

if (result.error) {
  console.error('❌ Failed to execute Bun runtime.');
  console.error('❌ Falló la ejecución del runtime Bun.');
  process.exit(1);
}

process.exit(result.status ?? 1);
