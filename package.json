{
  "name": "claude-code-source",
  "version": "0.1.0",
  "description": "Empaquetado npm del código fuente de Claude Code con build usando Bun.",
  "private": false,
  "author": "echostlab",
  "keywords": [
    "claude-code",
    "cli",
    "bun",
    "npm-package"
  ],
  "homepage": "https://github.com/echostlab/claude-code-source#readme",
  "bugs": {
    "url": "https://github.com/echostlab/claude-code-source/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echostlab/claude-code-source.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "preferGlobal": true,
  "bin": {
    "claude-code-source": "bin/claude-code-source"
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/require-bun.cjs",
    "docs/guia-empaquetado-npm.md",
    "README.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "check:bun": "node ./scripts/require-bun.cjs",
    "prebuild": "npm run check:bun",
    "build": "node ./scripts/build-cli.cjs",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.97.1",
    "@commander-js/extra-typings": "14.0.0",
    "@growthbook/growthbook": "1.6.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "axios": "1.16.1",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "unique-names-generator": "4.7.1",
    "emoji-regex": "10.6.0",
    "execa": "9.6.1",
    "get-east-asian-width": "1.6.0",
    "ignore": "7.0.5",
    "jsonc-parser": "3.3.1",
    "lodash-es": "4.18.1",
    "node-notifier": "10.0.1",
    "p-map": "7.0.4",
    "react": "19.2.6",
    "strip-ansi": "7.2.0",
    "detect-terminal": "2.0.0",
    "zod": "4.3.5"
  },
  "devDependencies": {}
}
